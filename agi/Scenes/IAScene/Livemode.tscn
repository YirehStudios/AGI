[sub_resource type="Shader" id="Shader_waves"]
code = "shader_type canvas_item;
uniform float voice_level = 0.5;
uniform float time_speed = 2.0;
uniform vec4 wave_color_center : source_color = vec4(1.0, 0.9, 0.6, 1.0);
uniform vec4 wave_color_edge : source_color = vec4(0.8, 0.5, 0.2, 1.0);
void fragment() {
    vec2 uv = UV * 2.0 - 1.0;
    float time = TIME * time_speed;
    vec3 final_color = vec3(0.0);
    float alpha = 0.0;
    for(float i = 1.0; i <= 5.0; i++) {
        float amp = (0.05 + voice_level * 0.35) / (i * 0.8);
        float freq = 1.5 * i;
        float wave = sin(uv.x * freq + time + i * 1.2) * amp;
        wave += cos(uv.x * freq * 0.4 - time * 0.7) * (amp * 0.5);
        float dist = abs(uv.y - wave);
        float glow = 0.008 / (dist + 0.002);
        glow = smoothstep(0.0, 1.2, glow);
        float fade = smoothstep(1.0, 0.0, abs(uv.x));
        glow *= fade;
        alpha += glow;
        vec3 col = mix(wave_color_edge.rgb, wave_color_center.rgb, glow);
        final_color += col * glow * (0.4 + voice_level * 0.4);
    }
    COLOR = vec4(final_color, clamp(alpha, 0.0, 1.0));
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_waves"]
shader = SubResource("Shader_waves")
shader_parameter/voice_level = 0.5
shader_parameter/time_speed = 2.0
shader_parameter/wave_color_center = Color(1, 0.9, 0.6, 1)
shader_parameter/wave_color_edge = Color(0.8, 0.5, 0.2, 1)

