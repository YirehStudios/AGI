shader_parameter/voice_level = 0.5
shader_parameter/time_speed = 2.0
shader_parameter/wave_color_center = Color(1, 0.9, 0.6, 1)
shader_parameter/wave_color_edge = Color(0.8, 0.5, 0.2, 1)

