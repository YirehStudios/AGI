[sub_resource type="Shader" id="Shader_chatgpt_blob"]
code = "shader_type canvas_item;

uniform float state : hint_range(0.0, 1.0) = 0.0;

void fragment() {
    vec2 uv = UV * 2.0 - 1.0;
    float a = atan(uv.y, uv.x);
    float r = length(uv);

    float time = TIME;

    float noise = sin(a * 3.0 + time) * 0.04;
    noise += cos(a * 2.0 - time * 0.8) * 0.03;
    noise += sin(a * 4.0 + time * 1.2) * 0.02;

    float base_radius = 0.65;
    float final_radius = base_radius + noise;

    float alpha = 1.0 - smoothstep(final_radius - 0.01, final_radius + 0.01, r);

    COLOR = vec4(1.0, 1.0, 1.0, alpha);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_chatgpt_blob"]
