# Usa Ubuntu como base limpia
FROM ubuntu:22.04

# Evita prompts interactivos
ENV DEBIAN_FRONTEND=noninteractive

# Instala dependencias necesarias para descargar y ejecutar
RUN apt-get update && apt-get install -y \
    wget \
    tar \
    unzip \
    bzip2 \
    libvulkan1 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Descarga los binarios precompilados (Igual que hacias antes localmente, pero ahora dentro de la imagen)
RUN wget https://github.com/ggerganov/llama.cpp/releases/download/b8232/llama-b8232-bin-ubuntu-vulkan-x64.tar.gz && \
    tar -xzf llama-b8232-bin-ubuntu-vulkan-x64.tar.gz && \
    mv build/bin/llama-server /usr/local/bin/ && \
    rm -rf build llama-b8232-bin-ubuntu-vulkan-x64.tar.gz

RUN wget https://github.com/ggerganov/whisper.cpp/releases/download/v1.7.4/whisper-v1.7.4-bin-ubuntu-x64.zip && \
    unzip whisper-v1.7.4-bin-ubuntu-x64.zip && \
    mv whisper-v1.7.4-bin-ubuntu-x64/whisper-cli /usr/local/bin/ && \
    rm -rf whisper-v1.7.4-bin-ubuntu-x64 whisper-v1.7.4-bin-ubuntu-x64.zip

RUN wget https://github.com/k2-fsa/sherpa-onnx/releases/download/v1.10.40/sherpa-onnx-v1.10.40-linux-x64.tar.bz2 && \
    tar -xjf sherpa-onnx-v1.10.40-linux-x64.tar.bz2 && \
    mv sherpa-onnx-v1.10.40-linux-x64/bin/sherpa-onnx-offline-tts /usr/local/bin/ && \
    mv sherpa-onnx-v1.10.40-linux-x64/lib/* /usr/local/lib/ && \
    rm -rf sherpa-onnx-v1.10.40-linux-x64 sherpa-onnx-v1.10.40-linux-x64.tar.bz2

# Actualiza las librerías del sistema para que encuentre los archivos de sherpa
RUN ldconfig

# Exponer el puerto de llama-server
EXPOSE 8080

# El entrypoint está vacío porque el BackendLauncher decidirá qué comando ejecutar (llama-server, whisper-cli, etc.)