# Volvemos a Ubuntu 22.04 (Nuestra roca sólida)
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# 1. Instalamos dependencias básicas y el SDK OFICIAL DE VULKAN (LunarG)
RUN apt-get update && apt-get install -y \
    wget gnupg2 software-properties-common tar unzip bzip2 libgomp1 build-essential git cmake && \
    wget -qO /etc/apt/trusted.gpg.d/lunarg.asc https://packages.lunarg.com/lunarg-signing-key-pub.asc && \
    wget -qO /etc/apt/sources.list.d/lunarg-vulkan-jammy.list http://packages.lunarg.com/vulkan/lunarg-vulkan-jammy.list && \
    apt-get update && apt-get install -y vulkan-sdk && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 2. LLAMA.CPP (Compilará impecable porque ahora tiene el Vulkan de última generación)
RUN git clone https://github.com/ggerganov/llama.cpp.git && \
    cd llama.cpp && \
    cmake -B build -DLLAMA_CURL=OFF -DBUILD_SHARED_LIBS=OFF -DGGML_VULKAN=ON && \
    cmake --build build -j 4 --config Release --target llama-server && \
    cp $(find build -type f -name "llama-server" | head -n 1) /usr/local/bin/llama-server && \
    cd .. && rm -rf llama.cpp

# 3. WHISPER.CPP 
RUN git clone -b v1.7.4 https://github.com/ggerganov/whisper.cpp.git && \
    cd whisper.cpp && \
    cmake -B build -DWHISPER_BUILD_EXAMPLES=ON -DWHISPER_BUILD_TESTS=OFF && \
    cmake --build build -j 4 --config Release && \
    if [ -f "build/bin/whisper-cli" ]; then cp build/bin/whisper-cli /usr/local/bin/whisper-cli; \
    elif [ -f "build/bin/main" ]; then cp build/bin/main /usr/local/bin/whisper-cli; \
    else cp $(find build -type f -name "whisper-cli" -o -name "main" | head -n 1) /usr/local/bin/whisper-cli; fi && \
    cd .. && rm -rf whisper.cpp

# 4. SHERPA-ONNX
RUN wget https://github.com/k2-fsa/sherpa-onnx/releases/download/v1.12.28/sherpa-onnx-v1.12.28-linux-x64-static.tar.bz2 && \
    tar -xjf sherpa-onnx-v1.12.28-linux-x64-static.tar.bz2 && \
    cp $(find . -name "sherpa-onnx-offline-tts" | head -n 1) /usr/local/bin/ && \
    rm -rf sherpa-onnx-v1.12.28-linux-x64-static*

RUN ldconfig
EXPOSE 8080